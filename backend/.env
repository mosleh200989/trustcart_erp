# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=
DB_USER=postgres
DB_PASSWORD=
DB_NAME=

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Application Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for payment redirects)
FRONTEND_URL=https://www.trustcart.com.bd

# ========== STEADFAST COURIER (Packzy) ==========
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
STEADFAST_WEBHOOK_SECRET=6523b699d69d283afe6635ac1b5be432883fb5e331916ed5c8f25624046c05c4
STEADFAST_WEBHOOK_CALLBACK_URL=https://api.trustkert.com/api/order-management/webhook/steadfast

# Hoorin Fraud Check API
# Get your API key from https://dash.hoorin.com
HOORIN_API_KEY=

# ========== SSLCommerz Payment Gateway ==========
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
# Use https://sandbox.sslcommerz.com for testing, https://securepay.sslcommerz.com for production
SSLCOMMERZ_IS_SANDBOX=true
# Public URL of your site (for success/fail/cancel/IPN callbacks)
SSLCOMMERZ_SUCCESS_URL=https://www.trustcart.com.bd/payment/success
SSLCOMMERZ_FAIL_URL=https://www.trustcart.com.bd/payment/fail
SSLCOMMERZ_CANCEL_URL=https://www.trustcart.com.bd/payment/cancel
SSLCOMMERZ_IPN_URL=https://api.trustkert.com/api/payments/ipn/sslcommerz
