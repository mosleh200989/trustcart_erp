# ==========================================
# TrustCart ERP - Environment Variables
# ==========================================

# ========== NODE ENVIRONMENT ==========
NODE_ENV=development

# ========== DATABASE CONFIGURATION ==========
# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trustcart_erp
DB_USER=trustcart_user
DB_PASSWORD=trustcart_secure_password
DATABASE_URL=postgresql://trustcart_user:trustcart_secure_password@localhost:5432/trustcart_erp

# ========== REDIS CONFIGURATION ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== APPLICATION SETTINGS ==========
APP_NAME=TrustCart ERP
APP_PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ========== JWT & AUTHENTICATION ==========
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_key
JWT_REFRESH_EXPIRATION=7d

# ========== EMAIL CONFIGURATION ==========
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@trustcart.com

# ========== SMS CONFIGURATION ==========
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ========== FILE UPLOAD ==========
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# ========== PAYMENT GATEWAY ==========
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ========== BKASH INTEGRATION ==========
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_MERCHANT_ID=your_merchant_id

# ========== LOGGING ==========
LOG_LEVEL=debug
LOG_FORMAT=json

# ========== CORS CONFIGURATION ==========
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ========== FRONTEND REACT ==========
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=TrustCart ERP

# ========== AWS S3 (Optional) ==========
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=trustcart-uploads

# ========== GOOGLE OAUTH (Optional) ==========
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ========== COMPANY SETTINGS ==========
COMPANY_NAME=TrustCart Ltd
COMPANY_EMAIL=info@trustcart.com
COMPANY_PHONE=+880-XXX-XXXXXXX
COMPANY_ADDRESS=Dhaka, Bangladesh
COMPANY_TAX_ID=

# ========== ANALYTICS ==========
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# ========== META CONVERSIONS API ==========
META_CAPI_ENABLED=false
META_CAPI_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_PIXEL_GROUPS=
META_CAPI_GRAPH_VERSION=v20.0
META_CAPI_CURRENCY=BDT

# Veshoj landing page (/admin/landing-pages/17, slug: veshoj)
# Keep the real access token only in the server .env/PM2 environment.
VESHOJ_META_CAPI_PIXEL_ID=33963706619940423
VESHOJ_META_CAPI_ACCESS_TOKEN=
VESHOJ_META_CAPI_TEST_EVENT_CODE=

# Google Sheets API Service Account (Presence sync)
# Share the target Google Sheet with this service account email as Editor.
# On VPS, set one of these manually in the real .env or server environment.
# Do not commit real service account JSON/private keys.
# GOOGLE_SERVICE_ACCOUNT_FILE should be an absolute path that exists on that server.
GOOGLE_SERVICE_ACCOUNT_FILE=/secure/path/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
SENTRY_DSN=

# ========== TELEGRAM BOT (Presence reminders) ==========
# Create a bot with @BotFather and paste only the token here on the server.
# Employees must start the bot first; then their Chat ID can be saved in Presence > Office Time.
TELEGRAM_BOT_TOKEN=



# ========== STEADFAST COURIER (Packzy) ==========
# Base URL from documentation: https://portal.packzy.com/api/v1
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=

# ── Steadfast Webhook Configuration ──
# 1. In the Steadfast dashboard, set Callback URL to:
#      https://your-domain.com/api/order-management/webhook/steadfast
# 2. Set Auth Token (Bearer) to a strong random string, then paste the SAME
#    string here so the server can verify incoming requests.
#    If left empty the webhook endpoint is OPEN (no auth) — NOT recommended for production.
STEADFAST_WEBHOOK_SECRET=

# ========== HOORIN FRAUD CHECK API ==========
# API for checking courier delivery fraud via Hoorin
# Get your API key from https://dash.hoorin.com
HOORIN_API_KEY=
